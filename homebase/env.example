##############################################################
# HOMEBASE — Configuration d'environnement
# Chemin : /.env (racine du projet Laravel)
# IMPORTANT : Ne jamais commiter ce fichier en production
##############################################################

APP_NAME="HomeBase"
APP_ENV=local
APP_KEY=                         # Généré par : php artisan key:generate
APP_DEBUG=true
APP_URL=http://homebase.test

# Localisation (France / Réunion)
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

# Logs
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

##############################################################
# BASE DE DONNÉES MySQL (Laragon)
##############################################################
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homebase_db
DB_USERNAME=root
DB_PASSWORD=                     # Vide par défaut dans Laragon

##############################################################
# CACHE & SESSION
##############################################################
BROADCAST_CONNECTION=log
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database        # Pour les jobs asynchrones IA
SESSION_DRIVER=file
SESSION_LIFETIME=120

##############################################################
# MAIL (optionnel — test local avec Mailpit inclus dans Laragon)
##############################################################
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@homebase.local"
MAIL_FROM_NAME="${APP_NAME}"

##############################################################
# API MISTRAL AI
# Clé gratuite développeur : https://console.mistral.ai
##############################################################
MISTRAL_API_KEY=                 # Coller votre clé ici
MISTRAL_API_URL=https://api.mistral.ai/v1
MISTRAL_DEFAULT_MODEL=mistral-small-latest
MISTRAL_MAX_TOKENS=1024
MISTRAL_TEMPERATURE=0.7

# Rate limiting pour protéger votre quota gratuit
MISTRAL_RATE_LIMIT_PER_MINUTE=10
MISTRAL_RATE_LIMIT_PER_DAY=100

##############################################################
# SÉCURITÉ
##############################################################
SANCTUM_STATEFUL_DOMAINS=homebase.test,localhost

# Clé de chiffrement supplémentaire pour les données sensibles
APP_CIPHER=AES-256-CBC
